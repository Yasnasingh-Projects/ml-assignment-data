   ],
   "source": [
    "from sklearn.compose import TransformedTargetRegressor\n",
    "\n",
    "# XGBoost with log target transformation\n",
    "xb_model = XGBRegressor(\n",
    "    objective='reg:squarederror',\n",
    "    random_state=42,\n",
    "    n_jobs=-1\n",
    ")\n",
    "\n",
    "xb_log_model = TransformedTargetRegressor(\n",
    "    regressor=xb_model,\n",
    "    func=np.log1p,\n",
    "    inverse_func=np.expm1\n",
    ")\n",
    "\n",
    "param_grid_xb = {\n",
    "    'regressor__n_estimators': [300, 500, 800],\n",
    "    'regressor__max_depth': [3, 4, 5],\n",
    "    'regressor__learning_rate': [0.01, 0.03, 0.05],\n",
    "    'regressor__subsample': [0.8],\n",
    "    'regressor__colsample_bytree': [0.8],\n",
    "    'regressor__min_child_weight': [1, 3, 5]\n",
    "}\n",
    "\n",
    "xb_cv = GridSearchCV(\n",
    "    xb_log_model,\n",
    "    param_grid_xb,\n",
    "    cv=3,\n",
    "    scoring='neg_mean_absolute_percentage_error',\n",
    "    n_jobs=-1\n",
    ")\n",
    "\n",
    "xb_cv.fit(X_train, y_train)\n",
    "\n",
    "best_xb = xb_cv.best_estimator_\n",
    "\n",
    "print(\"Best Parameters:\", xb_cv.best_params_)\n",
    "print(\"Best CV MAPE:\", -xb_cv.best_score_)"
   ]
