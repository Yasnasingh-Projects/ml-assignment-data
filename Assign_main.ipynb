   "source": [
    "from sklearn.preprocessing import StandardScaler\n",
    "\n",
    "# Identify numeric columns\n",
    "num_cols = X_train.select_dtypes(include=['float64', 'int64']).columns\n",
    "\n",
    "# Remove binary (0/1) columns\n",
    "binary_cols = [col for col in num_cols if X_train[col].nunique() <= 2]\n",
    "num_cols = [col for col in num_cols if col not in binary_cols]\n",
    "\n",
    "# Initialize scaler\n",
    "scaler = StandardScaler()\n",
    "\n",
    "# Scale only numeric columns\n",
    "X_train_scaled = X_train.copy()\n",
    "X_valid_scaled = X_valid.copy()\n",
    "\n",
    "X_train_scaled[num_cols] = scaler.fit_transform(X_train[num_cols])\n",
    "X_valid_scaled[num_cols] = scaler.transform(X_valid[num_cols])\n",
    "\n",
    "# Check\n",
    "X_train_scaled.head(15)"
   ]
  },
