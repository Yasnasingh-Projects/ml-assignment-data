   "source": [
    "# Use Random Forest feature importance to identify non-linear predictive features\n",
    "\n",
    "from sklearn.ensemble import RandomForestRegressor\n",
    "\n",
    "# Separate features and target\n",
    "X_fs = train_df.drop('Target Pressure (bar)', axis=1)\n",
    "y_fs = train_df['Target Pressure (bar)']\n",
    "\n",
    "# Train Random Forest for feature importance\n",
    "rf_fs = RandomForestRegressor(random_state=42)\n",
    "rf_fs.fit(X_fs, y_fs)\n",
    "\n",
    "# Create feature importance table\n",
    "importance_df = pd.DataFrame({\n",
    "    'Feature': X_fs.columns,\n",
    "    'Importance': rf_fs.feature_importances_\n",
    "}).sort_values(by='Importance', ascending=False)\n",
    "\n",
    "importance_df"
   ]
  },
