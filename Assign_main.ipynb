   "source": [
    "### 4.1 Linear Regression\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 43,
   "id": "0b777366",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Linear Regression Results:\n",
      "R²: 0.650107426852051\n",
      "MAPE: 0.7398217655562714\n",
      "RMSE: 0.2687569807771535\n"
     ]
    }
   ],
   "source": [
    "from sklearn.linear_model import LinearRegression\n",
    "from sklearn.metrics import mean_squared_error, mean_absolute_percentage_error, r2_score\n",
    "\n",
    "\n",
    "# Linear Regression model\n",
    "lr = LinearRegression()\n",
    "\n",
    "# Train using scaled training data\n",
    "lr.fit(X_train_scaled, y_train)\n",
    "\n",
    "# Predict using scaled validation data\n",
    "y_pred_lr = lr.predict(X_valid_scaled)\n",
    "y_pred_lr = np.clip(y_pred_lr, 0.001, None)  ## might remove this\n",
    "\n",
    "# Evaluation\n",
    "r2_lr = r2_score(y_valid, y_pred_lr)\n",
    "mape_lr = mean_absolute_percentage_error(y_valid, y_pred_lr)\n",
    "rmse_lr = np.sqrt(mean_squared_error(y_valid, y_pred_lr))\n",
    "\n",
    "print(\"Linear Regression Results:\")\n",
    "print(\"R²:\", r2_lr)\n",
    "print(\"MAPE:\", mape_lr)\n",
    "print(\"RMSE:\", rmse_lr)"
   ]
  },
