   "source": [
    "from sklearn.linear_model import Lasso\n",
    "\n",
    "# Initialize Basic Lasso model\n",
    "ls_basic = Lasso(alpha=0.1)\n",
    "\n",
    "# Train (USE SCALED DATA)\n",
    "ls_basic.fit(X_train_scaled, y_train)\n",
    "\n",
    "# Predict\n",
    "y_pred_ls_basic = ls_basic.predict(X_valid_scaled)\n",
    "y_pred_ls_basic = np.clip(y_pred_ls_basic, 0.001, None) ## might remove this\n",
    "\n",
    "# Metrics\n",
    "r2_ls_basic = r2_score(y_valid, y_pred_ls_basic)\n",
    "mape_ls_basic = mean_absolute_percentage_error(y_valid, y_pred_ls_basic)\n",
    "rmse_ls_basic = np.sqrt(mean_squared_error(y_valid, y_pred_ls_basic))\n",
    "\n",
    "print(\"Basic Lasso Performance:\")\n",
    "print(\"R2:\", r2_ls_basic)\n",
    "print(\"MAPE:\", mape_ls_basic)\n",
    "print(\"RMSE:\", rmse_ls_basic)"
   ]
  },
