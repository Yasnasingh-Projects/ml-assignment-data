    "# Step 1: Handle missing values in test data\n",
    "\n",
    "# Fill numerical missing values using median\n",
    "test_num_cols = test_df.select_dtypes(include=['int64', 'float64']).columns\n",
    "\n",
    "for col in test_num_cols:\n",
    "    test_df[col] = test_df[col].fillna(test_df[col].median())\n",
    "\n",
    "# Fill categorical missing values using mode\n",
    "test_cat_cols = test_df.select_dtypes(include=['object']).columns\n",
    "\n",
    "for col in test_cat_cols:\n",
    "    test_df[col] = test_df[col].fillna(test_df[col].mode()[0])"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 55,
   "id": "744af69e",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Step 2: Apply same feature engineering to test data\n",
    "\n",
    "test_df['Tank_Shape_Ratio'] = test_df['Tank Width (m)'] / (test_df['Tank Length (m)'] + 1e-6)\n",
    "test_df['Vapour_Ratio'] = test_df['Vapour Height (m)'] / (test_df['Tank Height (m)'] + 1e-6)\n",
    "test_df['Obstacle_Size_Ratio'] = test_df['Obstacle Width (m)'] / (test_df['Tank Width (m)'] + 1e-6)\n",
    "\n",
    "test_df['Temp_Difference'] = test_df['Vapour Temperature (K)'] - test_df['Liquid Temperature (K)']\n",
    "test_df['Temp_Ratio'] = test_df['Vapour Temperature (K)'] / (test_df['Liquid Temperature (K)'] + 1e-6)\n",
    "\n",
    "test_df['Tank_Volume'] = (\n",
    "    test_df['Tank Length (m)'] *\n",
    "    test_df['Tank Width (m)'] *\n",
    "    test_df['Tank Height (m)']\n",
    ")\n",
    "\n",
    "test_df['Vapour_Volume'] = (\n",
    "    test_df['Tank Length (m)'] *\n",
    "    test_df['Tank Width (m)'] *\n",
    "    test_df['Vapour Height (m)']\n",
    ")\n",
    "\n",
    "test_df['Vapour_Volume_Sq'] = test_df['Vapour_Volume'] ** 2\n",
    "\n",
    "test_df['Sensor_Distance'] = np.sqrt(\n",
    "    test_df['Sensor Position x']**2 +\n",
    "    test_df['Sensor Position y']**2 +\n",
    "    test_df['Sensor Position z']**2\n",
    ")\n",
    "\n",
    "test_df['Sensor_Distance_Sq'] = test_df['Sensor_Distance'] ** 2\n",
    "\n",
    "test_df['Sensor_Height_Ratio'] = test_df['Sensor Position z'] / (test_df['Tank Height (m)'] + 1e-6)\n",
    "\n",
    "test_df['Sensor_to_Vapour'] = (\n",
    "    test_df['Vapour Height (m)'] - test_df['Sensor Position z']\n",
    ")\n",
    "\n",
    "test_df['Distance_Normalized'] = test_df['Sensor_Distance'] / (test_df['Tank Height (m)'] + 1e-6)\n",
    "\n",
    "test_df['Temp_Vapour_Interaction'] = test_df['Temp_Difference'] * test_df['Vapour_Ratio']\n",
    "\n",
    "test_df['Vapour_Liquid_Ratio'] = (\n",
    "    test_df['Vapour Height (m)'] / (test_df['Liquid Ratio'] + 1e-6)\n",
    ")\n",
    "\n",
    "test_df['Relative_Sensor_Position'] = (\n",
    "    test_df['Sensor Position z'] / (test_df['Vapour Height (m)'] + 1e-6)\n",
    ")\n",
    "\n",
    "test_df['Distance_from_Vapour'] = abs(\n",
    "    test_df['Sensor Position z'] - test_df['Vapour Height (m)']\n",
    ")\n",
    "\n",
    "test_df['Log_Vapour_Volume'] = np.log1p(test_df['Vapour_Volume'])\n",
    "test_df['Log_Sensor_Distance'] = np.log1p(test_df['Sensor_Distance'])"
   ]
