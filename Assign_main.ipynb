   ],
   "source": [
    "from sklearn.model_selection import GridSearchCV\n",
    "from sklearn.linear_model import Lasso\n",
    "\n",
    "# Tuned Lasso\n",
    "\n",
    "param_grid_ls = {\n",
    "    'alpha': np.logspace(-3, 1, 20)\n",
    "}\n",
    "\n",
    "ls_tuned = Lasso(max_iter=50000, tol=0.001)\n",
    "\n",
    "ls_cv = GridSearchCV(\n",
    "    ls_tuned,\n",
    "    param_grid_ls,\n",
    "    cv=5,\n",
    "    scoring='neg_mean_absolute_percentage_error'\n",
    ")\n",
    "\n",
    "# Train (USE SCALED DATA)\n",
    "ls_cv.fit(X_train_scaled, y_train)\n",
    "\n",
    "# Best model\n",
    "best_ls = ls_cv.best_estimator_\n",
    "\n",
    "print(\"Best alpha:\", ls_cv.best_params_)\n",
    "print(\"Best CV MAPE:\", -ls_cv.best_score_)"
   ]
  },
